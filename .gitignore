# Build outputs
/build/
/build-*/
/out/
/.happypath/

# Recompiler output (derivative of copyrighted game code — regenerate locally)
/generated/

# Release packaging artifacts
/release-stage/
*.zip
# Downloaded toolchain artifacts cached by package_release.ps1 (embedded python +
# tcc zips) — fetched on demand, never committed.
/tools/_toolchain_cache/

# Local PlayStation assets (disc image, extracted boot EXE, memory cards)
/mmx6/
/isos/
/saves/

# Disc / image / memcard formats
*.bin
*.cue
*.iso
*.img
*.sub
*.ccd
*.mcd
*.mcr
*.chd

# Ghidra: keep instructions.txt + scripts/ + annotations/, drop the live DB + dumps
/ghidra/projects/
*.gpr
*.rep/
*.lock
*.lock~

# Local editor / cache files
.vs/
.vscode/
*.user
*.log

# Stdout/stderr redirect dumps from launch/debug helpers (root-level, local-only)
/_*.txt

# Runtime artifacts from psx-runtime launches
psx_crash.txt
psx_last_run_report.json
psx_screenshot.bmp
psx_freeze_heartbeat.json
starvation_dump.jsonl

# Diagnostic dumps from debug-server probes (root-level only; keep annotations/ tracked)
/*.json
/*.bmp
/*.png

# Python caches
__pycache__/
/_*.hex
/_*.json
/_*.bmp
/_*.png

# Local scratch/toolchain-probe artifacts (root-level only)
/_*.c
/_*.dll
/_*.exe

# MMX6 Tweaks variant tooling — local inputs/outputs (see tools/tweaks/, tools/tweaks_resolver.py)
/mmx6-tweaks/
/generated-tweaks/
/build-tweaks/
/game.tweaks-*.toml
# tweaks_engine.py port-validation scratch (staged vanilla bin, generated profiles, dumps)
/_portcheck/
